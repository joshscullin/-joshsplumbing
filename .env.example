# Copy this file to .env and fill in your own values.
# .env.example IS committed to git — it documents what variables
# the project needs without exposing the real values.

ADMIN_PASSWORD=change_me

# Twilio — missed-call webhook pipeline
# Find TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN at console.twilio.com (homepage)
# Phone numbers must be in E.164 format: +1 followed by 10 digits, e.g. +15551234567
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=change_me
TWILIO_PHONE_NUMBER=+15551234567
JOSH_PHONE_NUMBER=+15559876543
